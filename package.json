{
  "name": "@michlyn/mcpgateway",
  "version": "3.0.15",
  "description": "Enhanced version of supercorp-ai/supergateway, adding streamable http support and the ability to run MCP services based on both OpenAPI protocol interface documentation and higress MCP template files.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michlyn/mcpgateway.git"
  },
  "keywords": [
    "mcp",
    "stdio",
    "sse",
    "streamablehttp",
    "openapi",
    "gateway",
    "proxy",
    "bridge"
  ],
  "type": "module",
  "bin": {
    "mcpgateway": "dist/index.js",
    "openapi-to-mcp": "dist/cmd/openapi-to-mcp.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "format": "prettier --write 'src/**/*.ts' '*.json' '.prettierrc'",
    "format:check": "prettier --check 'src/**/*.ts' '*.json' '.prettierrc'",
    "test": "node test/test.js",
    "test:stdio": "node test/test-stdio-to-streamable-http.js",
    "test:sse": "node test/test-sse-to-streamable-http.js",
    "test:auth-headers": "node test/test-auth-headers.js",
    "test:direct-sse": "node test/test-direct-sse.js",
    "test:modified-sse": "node test/test-modified-sse-gateway.js",
    "test:ref-resolution": "node test/test-ref-resolution.js",
    "test:ignore-header": "node test/test-ignore-header.js",
    "test:remote-api": "node test/test-remote-api.js",
    "test:all": "node test/run-all-tests.js",
    "openapi-to-mcp": "node dist/cmd/openapi-to-mcp.js",
    "pub": "npm run build && npm config set registry https://registry.npmjs.org/ && npm publish --access public",
    "test:auth-headers-pass": "node test/test-auth-headers-pass.js"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "axios": "^1.9.0",
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "eventsource": "^3.0.6",
    "express": "^4.21.2",
    "js-yaml": "^4.1.0",
    "node-fetch": "^3.3.2",
    "uuid": "^11.1.0",
    "ws": "^8.18.1",
    "yargs": "^17.7.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.11",
    "@types/ws": "^8.18.1",
    "@types/yargs": "^17.0.33",
    "lint-staged": "^15.5.1",
    "openapi-types": "^12.1.3",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
